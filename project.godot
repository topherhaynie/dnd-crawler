; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="The Vault"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
config/icon="res://assets/icon.png"
config/main_scene="res://scenes/Main.tscn"
boot_splash/bg_color=Color(0.1, 0.1, 0.12, 1)
boot_splash/image="res://assets/icon.png"
boot_splash/fullsize=false
boot_splash/use_filter=true

[autoload]

HttpServer="*res://scripts/autoloads/HttpServer.cs"
ServiceBootstrap="*res://scripts/autoloads/ServiceBootstrap.gd"

[display]

window/subwindows/embed_subwindows=false

[dotnet]

project/assembly_name="The Vault"

[rendering]

textures/vram_compression/import_etc2_astc=true
